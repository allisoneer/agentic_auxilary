{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgenticConfig",
  "description": "Root configuration for all agentic tools.\n\nThis is the unified configuration that gets loaded from `agentic.toml` files.\nAll fields use `#[serde(default)]` so partial configs work correctly.",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "Optional JSON Schema URL for IDE autocomplete support.\nIn TOML: `\"$schema\" = \"file://./agentic.schema.json\"`",
      "type": [
        "string",
        "null"
      ]
    },
    "cli_tools": {
      "description": "CLI tools (grep, glob, ls) configuration.",
      "$ref": "#/$defs/CliToolsConfig",
      "default": {
        "extra_ignore_patterns": [],
        "glob_default_limit": 500,
        "grep_default_limit": 200,
        "just_execute_timeout_secs": 1800,
        "just_search_timeout_secs": 30,
        "ls_page_size": 100,
        "max_depth": 10,
        "pagination_cache_ttl_secs": 300
      }
    },
    "logging": {
      "description": "Logging and diagnostics configuration.",
      "$ref": "#/$defs/LoggingConfig",
      "default": {
        "json": false,
        "level": "info"
      }
    },
    "orchestrator": {
      "description": "Orchestrator session and timing configuration.",
      "$ref": "#/$defs/OrchestratorConfig",
      "default": {
        "agents": {
          "allow": [],
          "deny": []
        },
        "commands": {
          "allow": [],
          "deny": []
        },
        "compaction_threshold": 0.8,
        "inactivity_timeout_secs": 300,
        "session_deadline_secs": 3600
      }
    },
    "reasoning": {
      "description": "Tool-specific config for gpt5-reasoner.",
      "$ref": "#/$defs/ReasoningConfig",
      "default": {
        "empty_response_no_retry_after_secs": 600,
        "executor_model": "openai/gpt-5.2",
        "executor_timeout_secs": 2700,
        "max_completion_tokens": 128000,
        "optimizer_model": "anthropic/claude-sonnet-4.6",
        "stream_heartbeat_secs": 30
      }
    },
    "review": {
      "description": "Review tools configuration.",
      "$ref": "#/$defs/ReviewConfig",
      "default": {
        "run_timeout_secs": 1800
      }
    },
    "services": {
      "description": "External service configurations (Anthropic, Exa).",
      "$ref": "#/$defs/ServicesConfig",
      "default": {
        "anthropic": {
          "base_url": "https://api.anthropic.com"
        },
        "exa": {
          "base_url": "https://api.exa.ai"
        },
        "github": {
          "base_url": "https://api.github.com",
          "total_timeout_secs": 120
        },
        "linear": {
          "base_url": "https://api.linear.app/graphql",
          "connect_timeout_secs": 10,
          "request_timeout_secs": 60
        }
      }
    },
    "subagents": {
      "description": "Tool-specific config for coding-agent-tools subagents.",
      "$ref": "#/$defs/SubagentsConfig",
      "default": {
        "analyzer_model": "claude-sonnet-4-6",
        "locator_model": "claude-haiku-4-5",
        "runtime_timeout_secs": 3600
      }
    },
    "thoughts": {
      "description": "Thoughts tool configuration.",
      "$ref": "#/$defs/ThoughtsConfig",
      "default": {
        "add_reference_timeout_secs": 600
      }
    },
    "web_retrieval": {
      "description": "Web retrieval tool configuration.",
      "$ref": "#/$defs/WebRetrievalConfig",
      "default": {
        "default_max_bytes": 5242880,
        "default_search_results": 8,
        "max_search_results": 20,
        "request_timeout_secs": 30,
        "summarizer": {
          "max_tokens": 300,
          "model": "claude-haiku-4-5",
          "temperature": 0.2
        }
      }
    },
    "workspace_tools": {
      "description": "Workspace-local file and todo tools configuration.",
      "$ref": "#/$defs/WorkspaceToolsConfig",
      "default": {
        "workspace_apply_patch": false,
        "workspace_edit": false,
        "workspace_read": false,
        "workspace_todowrite": false
      }
    }
  },
  "$defs": {
    "AnthropicServiceConfig": {
      "description": "Anthropic API service configuration.",
      "type": "object",
      "properties": {
        "base_url": {
          "description": "Base URL for the Anthropic API.",
          "type": "string",
          "default": "https://api.anthropic.com"
        }
      }
    },
    "CliToolsConfig": {
      "description": "Configuration for CLI tools (grep, glob, ls).",
      "type": "object",
      "properties": {
        "extra_ignore_patterns": {
          "description": "Additional ignore patterns to append to builtin ignores.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "glob_default_limit": {
          "description": "Default `head_limit` for glob results (default: 500).",
          "type": "integer",
          "format": "uint32",
          "default": 500,
          "minimum": 0
        },
        "grep_default_limit": {
          "description": "Default `head_limit` for grep results (default: 200).",
          "type": "integer",
          "format": "uint32",
          "default": 200,
          "minimum": 0
        },
        "just_execute_timeout_secs": {
          "description": "Wall-clock timeout for `cli_just_execute` in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 1800,
          "minimum": 0
        },
        "just_search_timeout_secs": {
          "description": "Wall-clock timeout for `cli_just_search` in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 30,
          "minimum": 0
        },
        "ls_page_size": {
          "description": "Default page size for ls results (default: 100).",
          "type": "integer",
          "format": "uint32",
          "default": 100,
          "minimum": 0
        },
        "max_depth": {
          "description": "Maximum directory traversal depth (default: 10).",
          "type": "integer",
          "format": "uint32",
          "default": 10,
          "minimum": 0
        },
        "pagination_cache_ttl_secs": {
          "description": "Pagination cache TTL in seconds (default: 300 = 5 minutes).",
          "type": "integer",
          "format": "uint64",
          "default": 300,
          "minimum": 0
        }
      }
    },
    "ExaServiceConfig": {
      "description": "Exa search API service configuration.",
      "type": "object",
      "properties": {
        "base_url": {
          "description": "Base URL for the Exa API.",
          "type": "string",
          "default": "https://api.exa.ai"
        }
      }
    },
    "GitHubServiceConfig": {
      "description": "GitHub API service configuration.",
      "type": "object",
      "properties": {
        "base_url": {
          "description": "Base URL for the GitHub API.",
          "type": "string",
          "default": "https://api.github.com"
        },
        "total_timeout_secs": {
          "description": "Total timeout for multi-request operations in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 120,
          "minimum": 0
        }
      }
    },
    "LinearServiceConfig": {
      "description": "Linear API service configuration.",
      "type": "object",
      "properties": {
        "base_url": {
          "description": "Base URL for the Linear GraphQL API.",
          "type": "string",
          "default": "https://api.linear.app/graphql"
        },
        "connect_timeout_secs": {
          "description": "Connection establishment timeout in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 10,
          "minimum": 0
        },
        "request_timeout_secs": {
          "description": "Per-request timeout in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 60,
          "minimum": 0
        }
      }
    },
    "LoggingConfig": {
      "description": "Logging and diagnostics configuration.",
      "type": "object",
      "properties": {
        "json": {
          "description": "Whether to enable JSON-formatted logs.",
          "type": "boolean",
          "default": false
        },
        "level": {
          "description": "Log level (trace, debug, info, warn, error).",
          "type": "string",
          "default": "info"
        }
      }
    },
    "OrchestratorAgentsConfig": {
      "description": "Agent filtering policy for explicit orchestrator agent listing/selection.",
      "type": "object",
      "properties": {
        "allow": {
          "description": "Exact case-sensitive agent names to allow. Empty means no allowlist restriction.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "description": "Exact case-sensitive agent names to deny. Deny wins over allow.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "OrchestratorCommandsConfig": {
      "description": "Command filtering policy for orchestrator-exposed `OpenCode` commands.",
      "type": "object",
      "properties": {
        "allow": {
          "description": "Exact case-sensitive command names to allow. Empty means no allowlist restriction.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "description": "Exact case-sensitive command names to deny. Deny wins over allow.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "OrchestratorConfig": {
      "description": "Configuration for opencode-orchestrator-mcp.",
      "type": "object",
      "properties": {
        "agents": {
          "description": "Agent filtering policy for explicit orchestrator agent listing/selection.",
          "$ref": "#/$defs/OrchestratorAgentsConfig",
          "default": {
            "allow": [],
            "deny": []
          }
        },
        "commands": {
          "description": "Command filtering policy for orchestrator-exposed `OpenCode` commands.",
          "$ref": "#/$defs/OrchestratorCommandsConfig",
          "default": {
            "allow": [],
            "deny": []
          }
        },
        "compaction_threshold": {
          "description": "Context compaction threshold as fraction 0.0-1.0 (default: 0.80).",
          "type": "number",
          "format": "double",
          "default": 0.8
        },
        "inactivity_timeout_secs": {
          "description": "Inactivity timeout in seconds before session ends (default: 300 = 5 minutes).",
          "type": "integer",
          "format": "uint64",
          "default": 300,
          "minimum": 0
        },
        "session_deadline_secs": {
          "description": "Maximum session duration in seconds (default: 3600 = 1 hour).",
          "type": "integer",
          "format": "uint64",
          "default": 3600,
          "minimum": 0
        }
      }
    },
    "ReasoningConfig": {
      "description": "Configuration for gpt5-reasoner tool.",
      "type": "object",
      "properties": {
        "api_base_url": {
          "description": "Optional API base URL override for reasoning service.",
          "type": [
            "string",
            "null"
          ]
        },
        "empty_response_no_retry_after_secs": {
          "description": "Suppress empty-response retry when attempt duration exceeds this threshold.",
          "type": "integer",
          "format": "uint64",
          "default": 600,
          "minimum": 0
        },
        "executor_model": {
          "description": "`OpenRouter` model ID for executor/reasoner step.",
          "type": "string",
          "default": "openai/gpt-5.2"
        },
        "executor_timeout_secs": {
          "description": "Executor timeout in seconds.",
          "type": "integer",
          "format": "uint64",
          "default": 2700,
          "minimum": 0
        },
        "max_completion_tokens": {
          "description": "Upper bound for generated completion tokens (visible + reasoning).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": 128000,
          "minimum": 0
        },
        "max_input_tokens": {
          "description": "Max tokens allowed in the final input prompt after file injection.\nIf None, `gpt5_reasoner` enforces its internal default (`250_000`).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "optimizer_model": {
          "description": "`OpenRouter` model ID for optimizer step.",
          "type": "string",
          "default": "anthropic/claude-sonnet-4.6"
        },
        "reasoning_effort": {
          "description": "Optional reasoning effort level: low, medium, high, xhigh.",
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffortLevel"
            },
            {
              "type": "null"
            }
          ]
        },
        "stream_heartbeat_secs": {
          "description": "Heartbeat cadence for executor streaming logs.",
          "type": "integer",
          "format": "uint64",
          "default": 30,
          "minimum": 0
        }
      }
    },
    "ReasoningEffortLevel": {
      "description": "Schema-only enum for `reasoning_effort` IDE autocomplete.\nRuntime storage remains Option<String> for advisory validation semantics.",
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    },
    "ReviewConfig": {
      "description": "Configuration for review tools.",
      "type": "object",
      "properties": {
        "run_timeout_secs": {
          "description": "Wall-clock timeout for `review_run` sessions in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 1800,
          "minimum": 0
        }
      }
    },
    "ServicesConfig": {
      "description": "External service configurations.",
      "type": "object",
      "properties": {
        "anthropic": {
          "description": "Anthropic API configuration.",
          "$ref": "#/$defs/AnthropicServiceConfig",
          "default": {
            "base_url": "https://api.anthropic.com"
          }
        },
        "exa": {
          "description": "Exa search API configuration.",
          "$ref": "#/$defs/ExaServiceConfig",
          "default": {
            "base_url": "https://api.exa.ai"
          }
        },
        "github": {
          "description": "GitHub API configuration.",
          "$ref": "#/$defs/GitHubServiceConfig",
          "default": {
            "base_url": "https://api.github.com",
            "total_timeout_secs": 120
          }
        },
        "linear": {
          "description": "Linear API configuration.",
          "$ref": "#/$defs/LinearServiceConfig",
          "default": {
            "base_url": "https://api.linear.app/graphql",
            "connect_timeout_secs": 10,
            "request_timeout_secs": 60
          }
        }
      }
    },
    "SubagentsConfig": {
      "description": "Configuration for coding-agent-tools subagents (`ask_agent` tool).",
      "type": "object",
      "properties": {
        "analyzer_model": {
          "description": "Model for Analyzer subagent (deep analysis). Uses Claude CLI format.",
          "type": "string",
          "default": "claude-sonnet-4-6"
        },
        "locator_model": {
          "description": "Model for Locator subagent (fast discovery). Uses Claude CLI format.",
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "runtime_timeout_secs": {
          "description": "Wall-clock timeout for `ask_agent` runtime in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 3600,
          "minimum": 0
        }
      }
    },
    "ThoughtsConfig": {
      "description": "Configuration for thoughts MCP-adjacent operations.",
      "type": "object",
      "properties": {
        "add_reference_timeout_secs": {
          "description": "Wall-clock timeout for `thoughts_add_reference` in seconds. `0` disables the timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 600,
          "minimum": 0
        }
      }
    },
    "WebRetrievalConfig": {
      "description": "Configuration for web-retrieval tools (`web_fetch`, `web_search`).",
      "type": "object",
      "properties": {
        "default_max_bytes": {
          "description": "Default maximum bytes to fetch (default: 5MB).",
          "type": "integer",
          "format": "uint64",
          "default": 5242880,
          "minimum": 0
        },
        "default_search_results": {
          "description": "Default number of search results (default: 8).",
          "type": "integer",
          "format": "uint32",
          "default": 8,
          "minimum": 0
        },
        "max_search_results": {
          "description": "Maximum number of search results allowed (default: 20).",
          "type": "integer",
          "format": "uint32",
          "default": 20,
          "minimum": 0
        },
        "request_timeout_secs": {
          "description": "HTTP request timeout in seconds (default: 30).",
          "type": "integer",
          "format": "uint64",
          "default": 30,
          "minimum": 0
        },
        "summarizer": {
          "description": "Summarizer configuration for Haiku-based summarization.",
          "$ref": "#/$defs/WebSummarizerConfig",
          "default": {
            "max_tokens": 300,
            "model": "claude-haiku-4-5",
            "temperature": 0.2
          }
        }
      }
    },
    "WebSummarizerConfig": {
      "description": "Configuration for the web summarizer (Haiku).",
      "type": "object",
      "properties": {
        "max_tokens": {
          "description": "Maximum tokens for summary output (default: 300).",
          "type": "integer",
          "format": "uint32",
          "default": 300,
          "minimum": 0
        },
        "model": {
          "description": "Model to use for summarization (default: claude-haiku-4-5).",
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "temperature": {
          "description": "Temperature for summary generation (default: 0.2).",
          "type": "number",
          "format": "double",
          "default": 0.2
        }
      }
    },
    "WorkspaceToolsConfig": {
      "description": "Configuration for workspace-local file and todo tools.",
      "type": "object",
      "properties": {
        "workspace_apply_patch": {
          "description": "Enable the `workspace_apply_patch` tool.",
          "type": "boolean",
          "default": false
        },
        "workspace_edit": {
          "description": "Enable the `workspace_edit` tool.",
          "type": "boolean",
          "default": false
        },
        "workspace_read": {
          "description": "Enable the `workspace_read` tool.",
          "type": "boolean",
          "default": false
        },
        "workspace_todowrite": {
          "description": "Enable the `workspace_todowrite` tool.",
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
